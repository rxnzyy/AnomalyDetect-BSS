{
  "title": "Anomaly Detection Dashboard",
  "panels": [
    {
      "title": "Events per minute",
      "type": "graph",
      "targets": [
        {
          "measurement": "events",
          "groupBy": [
            {
              "type": "time",
              "params": ["1m"]
            },
            {
              "type": "fill",
              "params": ["null"]
            }
          ],
          "select": [
            [
              {
                "type": "field",
                "params": ["value"]
              },
              {
                "type": "count",
                "params": []
              }
            ]
          ]
        }
      ],
      "xaxis": {
        "mode": "time"
      }
    },
    {
      "title": "Anomalies detected",
      "type": "stat",
      "targets": [
        {
          "measurement": "anomalies",
          "select": [
            [
              {
                "type": "field",
                "params": ["severity"]
              },
              {
                "type": "count",
                "params": []
              }
            ]
          ]
        }
      ]
    }
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  }
}